{
  "name": "@local-latex-editor/frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@local-latex-editor/shared-types": "workspace:*",
    "@monaco-editor/react": "^4.6.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.8.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-pdf": "^7.7.0",
    "react-router-dom": "^6.22.0",
    "tailwind-merge": "^3.5.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@local-latex-editor/eslint-config": "workspace:*",
    "@local-latex-editor/typescript-config": "workspace:*",
    "@playwright/test": "^1.41.0",
    "@testing-library/react": "^14.2.0",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.57.0",
    "jsdom": "^24.0.0",
    "monaco-editor": "^0.46.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.0",
    "vitest": "^1.2.0"
  }
}
